# Black Vortex Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Server Configuration
# ===========================================

# Authentication Server Port
PORT=4000

# Multiplayer Server Port
MULTIPLAYER_PORT=4010

# ===========================================
# Security
# ===========================================

# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ===========================================
# Database
# ===========================================

# MongoDB Connection URI
# For local MongoDB:
MONGODB_URI=mongodb://localhost:27017/blackvortex

# For MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/blackvortex

# ===========================================
# AI Features (Optional)
# ===========================================

# Google Gemini API Key for AI Coach
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ===========================================
# CORS Configuration
# ===========================================

# Allowed origins (comma-separated)
# Use * for development, specific domains for production
CORS_ORIGIN=*

# ===========================================
# Rate Limiting
# ===========================================

# Login rate limit (attempts per window)
RATE_LIMIT_MAX=5

# Rate limit window in minutes
RATE_LIMIT_WINDOW=15

# ===========================================
# Logging
# ===========================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable file logging
LOG_TO_FILE=true

# ===========================================
# Production Settings
# ===========================================

# Node environment: development, production
NODE_ENV=development

# Enable HTTPS (requires SSL certificates)
ENABLE_HTTPS=false

# SSL Certificate paths (if HTTPS enabled)
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem